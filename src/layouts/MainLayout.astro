---
import Header from "./../components/Header.astro"
import Footer from "./../components/Footer.astro"

import "../styles/global.css"

const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/index-en' || Astro.url.pathname === '/index-en/';

const {title, } = Astro.props;
---

<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">

    {
      isHome && (<link href="https://fonts.googleapis.com/css2?family=Electrolize&display=swap" rel="stylesheet"/>)
    }

    <title>{title}</title>
    <script is:inline>
      // 立即执行，避免闪烁
      (function() {
        // 从 localStorage 读取主题，默认为 light
        const savedTheme = localStorage.getItem('theme') || 'light';
        window.isDark = savedTheme === 'dark';
        
        // 立即应用主题类
        if (window.isDark) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
        
        // 从 localStorage 读取语言，默认为 zh
        const savedLang = localStorage.getItem('language') || 'zh';
        window.currentLang = savedLang;
      })();
    </script>
    
    <script>
      // 主题切换函数
      function initTheme() {
        const savedTheme = localStorage.getItem('theme') || 'light';
        window.isDark = savedTheme === 'dark';
        
        // 更新图标
        window.updateToggleIcon = function() {
          const container = document.getElementById('toggle-icon');
          if (!container) return;
          
          if (window.isDark) {
            container.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" stroke-width="2" width="24" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" fill="none" viewBox="0 0 24 24" class="size-5"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9"></path><path d="M20 3v4"></path><path d="M22 5h-4"></path></svg>`;
          } else {
            container.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" stroke-width="2" width="24" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" fill="none" viewBox="0 0 24 24" class="size-5"><path d="M12 2v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="M20 12h2"></path><path d="m19.07 4.93-1.41 1.41"></path><path d="M15.947 12.65a4 4 0 0 0-5.925-4.128"></path><path d="M13 22H7a5 5 0 1 1 4.9-6H13a3 3 0 0 1 0 6Z"></path></svg>`;
          }
        };
        
        // 更新 Logo
        window.updateLogo = function() {
          const logoEl = document.getElementById('hutao667-logo');
          if (!logoEl) return;
          logoEl.src = "/favicon.ico";
        };
        
        // 切换主题
        window.toggleTheme = function() {
          window.isDark = !window.isDark;
          const newTheme = window.isDark ? 'dark' : 'light';
          
          // 更新 DOM
          document.documentElement.classList.toggle('dark', window.isDark);
          
          // 保存到 localStorage
          localStorage.setItem('theme', newTheme);
          
          // 更新 UI
          window.updateToggleIcon();
          window.updateLogo();
          
          // 触发自定义事件，通知其他可能的监听器
          window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: newTheme } }));
        };
        
        // 语言切换函数
        window.updateLanguageIcon = function() {
          const container = document.getElementById('language-icon');
          if (!container) return;
          
          // 显示当前可以切换到的语言（如果当前是中文，显示EN；如果是英文，显示中）
          const langText = window.currentLang === 'zh' ? 'EN' : '中';
          
          container.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
              <path d="M2 12h20"/>
            </svg>
            <span class="text-[10px] font-bold relative z-10" style="margin-top: 1px;">${langText}</span>
          `;
        };
        
        window.toggleLanguage = function() {
          // 切换语言
          const oldLang = window.currentLang;
          window.currentLang = window.currentLang === 'zh' ? 'en' : 'zh';
          
          console.log('Language switched from', oldLang, 'to', window.currentLang);
          
          // 保存到 localStorage
          localStorage.setItem('language', window.currentLang);
          
          // 更新图标
          window.updateLanguageIcon();
          
          // 触发语言切换事件
          window.dispatchEvent(new CustomEvent('languageChanged', { 
            detail: { language: window.currentLang } 
          }));
          
          // 获取当前路径
          const currentPath = window.location.pathname;
          
          // 如果在博客列表页面，不刷新，通过事件通知页面更新
          if (currentPath === '/blog' || currentPath === '/blog/') {
            // 博客列表页面会监听 languageChanged 事件并更新内容
            console.log('Blog page - dispatched languageChanged event');
            return;
          }
          
          // 如果在首页或关于页面，跳转到对应语言版本
          if (currentPath === '/' || currentPath === '/index' || currentPath === '/index/') {
            const targetUrl = window.currentLang === 'en' ? '/index-en' : '/';
            console.log('Home page - redirecting to', targetUrl);
            window.location.href = targetUrl;
            return;
          }
          
          if (currentPath === '/about' || currentPath === '/about/') {
            const targetUrl = window.currentLang === 'en' ? '/about-en' : '/about';
            console.log('About page - redirecting to', targetUrl);
            window.location.href = targetUrl;
            return;
          }
          
          if (currentPath === '/about-en' || currentPath === '/about-en/') {
            const targetUrl = window.currentLang === 'zh' ? '/about' : '/about-en';
            console.log('About-en page - redirecting to', targetUrl);
            window.location.href = targetUrl;
            return;
          }
          
          if (currentPath === '/index-en' || currentPath === '/index-en/') {
            const targetUrl = window.currentLang === 'zh' ? '/' : '/index-en';
            console.log('Index-en page - redirecting to', targetUrl);
            window.location.href = targetUrl;
            return;
          }
          
          // 如果在博客文章页面，跳转到博客列表
          const articleMatch = currentPath.match(/\/(\d{4})\/(\d{1,2})\/([^\/]+)\/?$/);
          if (articleMatch) {
            console.log('Article page - redirecting to blog list');
            window.location.href = '/blog';
          }
        };
        
        // 初始化 UI
        window.updateToggleIcon();
        window.updateLogo();
        window.updateLanguageIcon();
      }
      
      // DOM 加载完成后初始化
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTheme);
      } else {
        initTheme();
      }
    </script>
  </head>
  <body>
    <div class="grid"></div>
    <div class="page flex flex-col min-h-screen">
        <Header />
        <main class={`flex-grow flex justify-center ${!isHome ? 'pt-20 lg:pt-24' : ''}`}>
          <slot />
        </main>
        { !isHome && <Footer /> }
        <div class="notch"></div>
        <div class="notch-top"></div>
    </div>
  </body>
</html>