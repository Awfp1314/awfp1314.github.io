---
import Header from "./../components/Header.astro"
import Footer from "./../components/Footer.astro"

import "../styles/global.css"

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index-en' || pathname === '/index-en/';
const defaultLang = pathname.includes('/index-en') || pathname.includes('/about-en') || pathname.includes('/blog-en') ? 'en' : 'zh';

const {
  title,
  description = 'HUTAO667 的个人技术博客，分享 AI 应用开发、项目实践和技术思考。',
  lang = defaultLang,
  ogType = 'website',
  publishedTime,
  tags = [],
  alternateLinks = [],
} = Astro.props;
const htmlLang = lang === 'en' ? 'en' : 'zh-CN';
const resolvedAlternateLinks = alternateLinks.map((link) => ({
  ...link,
  href: new URL(link.href, Astro.site ?? Astro.url).href,
}));
---

<html lang={htmlLang} data-page-lang={lang}>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content={ogType}>
    <meta property="og:url" content={Astro.url.href}>
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime}>}
    {ogType === 'article' && tags.map((tag) => <meta property="article:tag" content={tag}>)}
    <link rel="canonical" href={Astro.url.href}>
    {resolvedAlternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={link.href}>
    ))}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">

    {isHome && (<link href="https://fonts.googleapis.com/css2?family=Electrolize&display=swap" rel="stylesheet"/>)}

    <title>{title}</title>
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme') || 'light';
        window.isDark = savedTheme === 'dark';
        document.documentElement.classList.toggle('dark', window.isDark);

        const pageLang = document.documentElement.dataset.pageLang === 'en' ? 'en' : 'zh';
        window.currentLang = pageLang;
        localStorage.setItem('language', pageLang);
      })();
    </script>
    
    <script>
      function initTheme() {
        const savedTheme = localStorage.getItem('theme') || 'light';
        window.isDark = savedTheme === 'dark';
        
        window.updateToggleIcon = function() {
          const container = document.getElementById('toggle-icon');
          if (!container) return;
          container.innerHTML = window.isDark
            ? `<svg xmlns="http://www.w3.org/2000/svg" stroke-width="2" width="24" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" fill="none" viewBox="0 0 24 24" class="size-5"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9"></path><path d="M20 3v4"></path><path d="M22 5h-4"></path></svg>`
            : `<svg xmlns="http://www.w3.org/2000/svg" stroke-width="2" width="24" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" fill="none" viewBox="0 0 24 24" class="size-5"><path d="M12 2v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="M20 12h2"></path><path d="m19.07 4.93-1.41 1.41"></path><path d="M15.947 12.65a4 4 0 0 0-5.925-4.128"></path><path d="M13 22H7a5 5 0 1 1 4.9-6H13a3 3 0 0 1 0 6Z"></path></svg>`;
        };
        
        window.updateLogo = function() {
          const logoEl = document.getElementById('hutao667-logo');
          if (logoEl) logoEl.src = "/favicon.ico";
        };
        
        window.toggleTheme = function() {
          window.isDark = !window.isDark;
          const newTheme = window.isDark ? 'dark' : 'light';
          document.documentElement.classList.toggle('dark', window.isDark);
          localStorage.setItem('theme', newTheme);
          window.updateToggleIcon();
          window.updateLogo();
          window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: newTheme } }));
        };
        
        window.updateNavLinks = function() {
          document.querySelectorAll('.nav-link').forEach(link => {
            const zhHref = link.getAttribute('data-zh-href');
            const enHref = link.getAttribute('data-en-href');
            const zhLabel = link.getAttribute('data-zh-label');
            const enLabel = link.getAttribute('data-en-label');
            if (window.currentLang === 'zh') {
              if (zhHref) link.setAttribute('href', zhHref);
              if (zhLabel) link.textContent = zhLabel;
            } else {
              if (enHref) link.setAttribute('href', enHref);
              if (enLabel) link.textContent = enLabel;
            }
          });
        };
        
        window.updateLanguageIcon = function() {
          const enEl = document.getElementById('lang-en');
          const zhEl = document.getElementById('lang-zh');
          if (!enEl || !zhEl) return;
          enEl.className = window.currentLang === 'en' ? 'text-base text-foreground transition-all' : 'text-sm text-muted-foreground transition-all';
          zhEl.className = window.currentLang === 'zh' ? 'text-base text-foreground transition-all' : 'text-sm text-muted-foreground transition-all';
        };
        
        function replaceWithLanguagePage(targetPath) {
          if (!targetPath || window.location.pathname === targetPath) return;
          window.location.replace(targetPath);
        }

        window.toggleLanguage = function() {
          window.currentLang = window.currentLang === 'zh' ? 'en' : 'zh';
          localStorage.setItem('language', window.currentLang);
          window.updateLanguageIcon();
          window.updateNavLinks();
          window.dispatchEvent(new CustomEvent('languageChanged', { detail: { language: window.currentLang } }));
          
          const currentPath = window.location.pathname;
          if (currentPath === '/blog' || currentPath === '/blog/') {
            replaceWithLanguagePage(window.currentLang === 'en' ? '/blog-en' : '/blog');
            return;
          }
          if (currentPath === '/blog-en' || currentPath === '/blog-en/') {
            replaceWithLanguagePage(window.currentLang === 'zh' ? '/blog' : '/blog-en');
            return;
          }
          if (currentPath === '/' || currentPath === '/index' || currentPath === '/index/') {
            replaceWithLanguagePage(window.currentLang === 'en' ? '/index-en' : '/');
            return;
          }
          if (currentPath === '/about' || currentPath === '/about/') {
            replaceWithLanguagePage(window.currentLang === 'en' ? '/about-en' : '/about');
            return;
          }
          if (currentPath === '/about-en' || currentPath === '/about-en/') {
            replaceWithLanguagePage(window.currentLang === 'zh' ? '/about' : '/about-en');
            return;
          }
          if (currentPath === '/index-en' || currentPath === '/index-en/') {
            replaceWithLanguagePage(window.currentLang === 'zh' ? '/' : '/index-en');
            return;
          }
          const alternateSlugEl = document.querySelector('[data-alternate-slug]');
          const articleAlternateSlug = alternateSlugEl?.getAttribute('data-alternate-slug');
          if (articleAlternateSlug) {
            replaceWithLanguagePage('/' + articleAlternateSlug.replace(/^\/|\/$/g, '') + '/');
          }
        };
        
        window.updateToggleIcon();
        window.updateLogo();
        window.updateLanguageIcon();
        window.updateNavLinks();
      }
      
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTheme);
      } else {
        initTheme();
      }
    </script>
  </head>
  <body>
    <div class="grid"></div>
    <div class="page flex flex-col min-h-screen">
        <Header lang={lang} />
        <main class={`flex-grow flex justify-center ${!isHome ? 'pt-20 lg:pt-24' : ''}`}>
          <slot />
        </main>
        { !isHome && <Footer /> }
        <div class="notch"></div>
        <div class="notch-top"></div>
    </div>
  </body>
</html>
