---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import Link from "../../components/Link.astro";

// 获取当前语言（从localStorage或默认为中文）
const currentLang = 'zh'; // 服务端默认中文，客户端会动态切换

const allPosts = await getCollection("blog");
allPosts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate);
  const dateB = new Date(b.data.pubDate);
  return dateB - dateA; // Descending order
});

function formatDate(dateString) {
  const date = new Date(dateString);
  const day = String(date.getDate()).padStart(2, '0');
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const year = date.getFullYear();
  return `${year}-${month}-${day}`;
}

---
<MainLayout title="Archive - Blog">
  <div class="max-w-4xl mx-auto px-6 py-12 w-full animate-fade-in">
    <div class="mb-12 border-b border-border pb-8 animate-slide-up" style="animation-delay: 0.1s;">
      <h1 class="text-3xl md:text-4xl font-bold text-foreground mb-4" id="blog-title">博客归档</h1>
      <p class="text-muted-foreground font-mono text-sm" id="blog-description">探索技术世界，记录开发心得。</p>
      
      <div class="mt-6">
        <input 
          type="text" 
          id="search-input"
          placeholder="搜索文章..."
          class="w-full px-4 py-2 bg-muted/30 border border-border rounded-lg text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
        />
      </div>
    </div>
    
    <div class="space-y-4 animate-slide-up" id="posts-container" style="animation-delay: 0.3s;">
    </div>
  </div>

  <script define:vars={{ allPosts }}>
    const allPostsData = allPosts;
    const container = document.getElementById('posts-container');
    const searchInput = document.getElementById('search-input');
    
    // 语言翻译
    const translations = {
      zh: {
        title: '博客归档',
        description: '探索技术世界，记录开发心得。',
        search: '搜索文章...'
      },
      en: {
        title: 'Blog Archive',
        description: 'Explore the tech world, document development insights.',
        search: 'Search posts...'
      }
    };
    
    // 获取当前语言
    function getCurrentLang() {
      return localStorage.getItem('language') || 'zh';
    }
    
    // 根据语言过滤文章
    function getPostsByLang(lang) {
      return allPostsData.filter(post => post.data.lang === lang);
    }
    
    let posts = getPostsByLang(getCurrentLang());

    function formatDate(dateString) {
      const date = new Date(dateString);
      const day = String(date.getDate()).padStart(2, '0');
      const month = String(date.getMonth() + 1).padStart(2, '0');
      const year = date.getFullYear();
      return `${year}-${month}-${day}`;
    }

    function renderPosts(filteredPosts) {
      container.innerHTML = filteredPosts.map(post => `
        <a href="/${post.id}/" class="post-link group block p-5 bg-muted/30 hover:bg-muted/50 border border-border rounded-xl transition-all hover:translate-x-1 h-[180px] flex flex-col" data-post-id="${post.id}">
          <div class="flex flex-col md:flex-row md:items-start justify-between gap-4 flex-grow">
            <div class="flex-grow flex flex-col min-w-0">
              <h2 class="text-lg font-bold text-foreground group-hover:text-primary transition-colors mb-1 line-clamp-1">
                ${post.data.title}
              </h2>
              <p class="text-muted-foreground line-clamp-2 text-sm leading-relaxed mb-3">
                ${post.data.description}
              </p>
              ${post.data.tags ? `
                <div class="flex flex-wrap gap-2 overflow-hidden" style="max-height: 3rem;">
                  ${post.data.tags.map(tag => `
                    <span class="text-[10px] uppercase tracking-widest font-mono bg-background px-2 py-0.5 border border-border rounded text-muted-foreground whitespace-nowrap">
                      ${tag}
                    </span>
                  `).join('')}
                </div>
              ` : ''}
            </div>
            <div class="shrink-0 flex items-center md:flex-col md:items-end gap-2 text-muted-foreground font-mono text-sm">
              <span>${formatDate(post.data.pubDate)}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden md:block opacity-0 group-hover:opacity-100 transition-opacity"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      `).join('');
      
      // 为所有文章链接添加点击事件，保存滚动位置
      document.querySelectorAll('.post-link').forEach(link => {
        link.addEventListener('click', function(e) {
          // 保存当前滚动位置
          sessionStorage.setItem('blogListScrollPosition', window.scrollY.toString());
          // 保存当前搜索关键词
          sessionStorage.setItem('blogListSearchQuery', searchInput.value);
        });
      });
    }

    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      const filtered = posts.filter(post => 
        post.data.title.toLowerCase().includes(query) || 
        post.data.description.toLowerCase().includes(query) ||
        (post.data.tags && post.data.tags.some(tag => tag.toLowerCase().includes(query)))
      );
      renderPosts(filtered);
    });
    
    // 更新页面文本
    function updatePageText(lang) {
      const t = translations[lang];
      document.getElementById('blog-title').textContent = t.title;
      document.getElementById('blog-description').textContent = t.description;
      document.getElementById('search-input').placeholder = t.search;
    }
    
    // 监听语言切换事件
    window.addEventListener('languageChanged', (e) => {
      const newLang = e.detail.language;
      posts = getPostsByLang(newLang);
      renderPosts(posts);
      updatePageText(newLang);
      searchInput.value = ''; // 清空搜索
    });
    
    // 页面加载时初始化语言
    function initLanguage() {
      const currentLang = getCurrentLang();
      posts = getPostsByLang(currentLang);
      updatePageText(currentLang);
      renderPosts(posts);
      
      // 恢复搜索关键词
      const savedSearchQuery = sessionStorage.getItem('blogListSearchQuery');
      if (savedSearchQuery) {
        searchInput.value = savedSearchQuery;
        // 触发搜索
        const query = savedSearchQuery.toLowerCase();
        const filtered = posts.filter(post => 
          post.data.title.toLowerCase().includes(query) || 
          post.data.description.toLowerCase().includes(query) ||
          (post.data.tags && post.data.tags.some(tag => tag.toLowerCase().includes(query)))
        );
        renderPosts(filtered);
      }
      
      // 恢复滚动位置
      const savedScrollPosition = sessionStorage.getItem('blogListScrollPosition');
      if (savedScrollPosition) {
        // 使用 setTimeout 确保 DOM 完全渲染和动画完成
        setTimeout(() => {
          window.scrollTo({
            top: parseInt(savedScrollPosition, 10),
            behavior: 'instant' // 立即滚动，不使用平滑动画
          });
          // 清除保存的滚动位置，避免下次进入时还原到这个位置
          sessionStorage.removeItem('blogListScrollPosition');
          sessionStorage.removeItem('blogListSearchQuery');
        }, 100); // 增加延迟到 100ms
      }
    }
    
    // 初始化
    initLanguage();
  </script>

  <style>
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in {
      animation: fadeIn 0.6s ease-out forwards;
    }

    .animate-slide-up {
      opacity: 0;
      animation: slideUp 0.8s ease-out forwards;
    }
  </style>
</MainLayout>