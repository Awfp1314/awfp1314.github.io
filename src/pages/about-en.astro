---
import MainLayout from "../layouts/MainLayout.astro";
import Link from "../components/Link.astro";
---

<MainLayout title="About - HUTAO667" description="About HUTAO667: an AI application developer focused on LLMs, MCP, Function Calling, Unreal Engine tools, and web development." lang="en">
  <section class="max-w-4xl mx-auto px-6 py-12 w-full animate-fade-in">
    <div class="border-b border-border pb-8 mb-8">
      <p class="text-sm uppercase tracking-[0.3em] text-muted-foreground mb-3">About</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-foreground">About Me</h1>
      <p class="mt-5 text-lg text-muted-foreground leading-relaxed">
        Hi, I am HUTAO667, a developer focused on AI application development and practical engineering.
      </p>
    </div>

    <div class="grid gap-6 text-foreground leading-8">
      <p>
        I work with LLM applications, multi-model integration, Function Calling, MCP, RAG, and the practical delivery of these capabilities in real projects.
      </p>
      <p>
        This blog documents my technical notes, project retrospectives, and problem-solving process. Topics include AI application development, Unreal Engine tools, Python desktop apps, full-stack web development, and productivity workflows.
      </p>
      <div class="rounded-2xl border border-border bg-muted/30 p-6">
        <h2 class="text-xl font-semibold mb-4">Current Focus</h2>
        <ul class="list-disc pl-6 space-y-2 text-muted-foreground">
          <li>LLM application engineering: model integration, tool calling, and context management</li>
          <li>RAG and knowledge bases: document processing, retrieval augmentation, and evaluation</li>
          <li>Unreal Engine tooling: AI-powered desktop tools and editor assistance</li>
          <li>Personal knowledge management: Obsidian, automated sync, and publishing workflows</li>
        </ul>
      </div>
      <p>
        You can read posts in the <Link href="/blog">blog archive</Link> or visit my <Link href="https://github.com/Awfp1314">GitHub</Link> for projects.
      </p>
    </div>
  </section>
</MainLayout>
